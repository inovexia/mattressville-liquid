        { "type": "faq", "settings": { "q": "What is “sleep efficiency”?", "a": "Sleep efficiency is the percentage of time you’re asleep while you’re in bed. Higher usually means better sleep quality." } },
        { "type": "faq", "settings": { "q": "What is WASO?", "a": "WASO means “wake after sleep onset” — minutes awake after you’ve fallen asleep." } },
        { "type": "faq", "settings": { "q": "When should I consider replacing my mattress?", "a": "If you’re waking up sore, the mattress is sagging, or you sleep better elsewhere, it’s worth checking mattress fit." } },
