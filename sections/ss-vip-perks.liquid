{%- comment -%}
  SS VIP Perks
  - Editable perk cards (add/remove/reorder in theme editor)
  - Optional image column (left or right)
  - Built-in customer tag gate (restricts whole section to tagged customers)
  Save as: sections/ss-vip-perks.liquid
{%- endcomment -%}

{%- liquid
  assign gate_pass = true
  if section.settings.enable_gate
    assign gate_pass = false
    if customer and customer.tags contains section.settings.gate_tag
      assign gate_pass = true
    endif
  endif
-%}

<style>
  #ss-vip-perks-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #ss-vip-perks-{{ section.id }} .svp-container {
    max-width: 120rem;
    margin: 0 auto;
    padding: 0 2rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-layout {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  #ss-vip-perks-{{ section.id }} .svp-layout.has-image {
    grid-template-columns: 1fr 1.25fr;
  }
  #ss-vip-perks-{{ section.id }} .svp-layout.image-right .svp-media { order: 2; }
  #ss-vip-perks-{{ section.id }} .svp-media {
    border-radius: 20px;
    overflow: hidden;
  }
  #ss-vip-perks-{{ section.id }} .svp-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #ss-vip-perks-{{ section.id }} .svp-eyebrow {
    display: inline-block;
    padding: 0.5rem 1.4rem;
    border-radius: 20px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    border: 1px solid {{ section.settings.accent_color | color_modify: 'alpha', 0.25 }};
    color: {{ section.settings.accent_color }};
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-heading {
    margin: 0 0 1.2rem;
    font-size: 3.6rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: {{ section.settings.heading_color }};
  }
  #ss-vip-perks-{{ section.id }} .svp-subtext {
    margin: 0 0 3rem;
    font-size: 1.6rem;
    line-height: 1.6;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.75 }};
    max-width: 52rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 1.6rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-card {
    background: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.heading_color | color_modify: 'alpha', 0.1 }};
    border-radius: 18px;
    padding: 2.4rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  #ss-vip-perks-{{ section.id }} .svp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
  #ss-vip-perks-{{ section.id }} .svp-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    margin-bottom: 1.4rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-icon {
    width: 4.4rem;
    height: 4.4rem;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    border: 1px solid {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }};
    color: {{ section.settings.accent_color }};
  }
  #ss-vip-perks-{{ section.id }} .svp-icon svg {
    width: 2.2rem;
    height: 2.2rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-value {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: {{ section.settings.accent_color }};
    line-height: 1;
    white-space: nowrap;
  }
  #ss-vip-perks-{{ section.id }} .svp-card-title {
    margin: 0 0 0.6rem;
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: {{ section.settings.heading_color }};
  }
  #ss-vip-perks-{{ section.id }} .svp-card-text {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.55;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.7 }};
  }
  #ss-vip-perks-{{ section.id }} .svp-locked {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    padding: 6rem 2rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-locked h2 {
    font-size: 2.8rem;
    margin: 0 0 1.2rem;
    color: {{ section.settings.heading_color }};
  }
  #ss-vip-perks-{{ section.id }} .svp-locked p {
    font-size: 1.6rem;
    line-height: 1.6;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.75 }};
    margin: 0 0 2.4rem;
  }
  #ss-vip-perks-{{ section.id }} .svp-btn {
    display: inline-block;
    padding: 1.3rem 3.2rem;
    border-radius: 12px;
    background: {{ section.settings.accent_color }};
    color: #ffffff;
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  #ss-vip-perks-{{ section.id }} .svp-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
  }
  @media screen and (max-width: 989px) {
    #ss-vip-perks-{{ section.id }} .svp-layout.has-image {
      grid-template-columns: 1fr;
    }
    #ss-vip-perks-{{ section.id }} .svp-layout.image-right .svp-media { order: 0; }
    #ss-vip-perks-{{ section.id }} .svp-media { max-height: 34rem; }
    #ss-vip-perks-{{ section.id }} .svp-grid { grid-template-columns: repeat(2, 1fr); }
    #ss-vip-perks-{{ section.id }} .svp-heading { font-size: 2.8rem; }
  }
  @media screen and (max-width: 640px) {
    #ss-vip-perks-{{ section.id }} .svp-grid { grid-template-columns: 1fr; }
  }
</style>

<div id="ss-vip-perks-{{ section.id }}">
  <div class="svp-container">
    {%- if gate_pass -%}
      <div class="svp-layout{% if section.settings.image != blank %} has-image{% endif %}{% if section.settings.image_position == 'right' %} image-right{% endif %}">
        {%- if section.settings.image != blank -%}
          <div class="svp-media">
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
          </div>
        {%- endif -%}

        <div class="svp-content">
          {%- if section.settings.eyebrow != blank -%}
            <span class="svp-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="svp-heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subtext != blank -%}
            <p class="svp-subtext">{{ section.settings.subtext }}</p>
          {%- endif -%}

          <div class="svp-grid">
            {%- for block in section.blocks -%}
              <div class="svp-card" {{ block.shopify_attributes }}>
                <div class="svp-card-top">
                  <span class="svp-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'percent' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                      {%- when 'truck' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="14" height="12" rx="1"/><path d="M15 8h4l3 4v4h-7"/><circle cx="6" cy="18.5" r="2"/><circle cx="17.5" cy="18.5" r="2"/></svg>
                      {%- when 'star' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- when 'tag' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L11 3.83A2 2 0 0 0 9.59 3.24H4a1 1 0 0 0-1 1v5.59c0 .53.21 1.04.59 1.41l9.58 9.59a2 2 0 0 0 2.83 0l4.59-4.59a2 2 0 0 0 0-2.83z"/><circle cx="7.5" cy="7.5" r="1"/></svg>
                      {%- when 'gift' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5C11 3 12 8 12 8s1-5 4.5-5a2.5 2.5 0 0 1 0 5"/></svg>
                      {%- when 'crown' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h20l-2-11-5 4-3-7-3 7-5-4-2 11z"/><path d="M4 21h16"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    {%- endcase -%}
                  </span>
                  {%- if block.settings.value != blank -%}
                    <span class="svp-value">{{ block.settings.value }}</span>
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="svp-card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="svp-card-text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="svp-locked">
        <h2>{{ section.settings.locked_heading }}</h2>
        <p>{{ section.settings.locked_text }}</p>
        {%- unless customer -%}
          <a class="svp-btn" href="/account/login?return_url={{ request.path | url_encode }}">{{ section.settings.locked_button_label }}</a>
        {%- endunless -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "SS VIP Perks",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Access control"
    },
    {
      "type": "checkbox",
      "id": "enable_gate",
      "label": "Restrict to tagged customers",
      "default": true
    },
    {
      "type": "text",
      "id": "gate_tag",
      "label": "Customer tag required",
      "default": "vip"
    },
    {
      "type": "text",
      "id": "locked_heading",
      "label": "Locked state heading",
      "default": "Members only"
    },
    {
      "type": "textarea",
      "id": "locked_text",
      "label": "Locked state message",
      "default": "This page is exclusive to Mville+ VIP members. Log in to your account to view your perks."
    },
    {
      "type": "text",
      "id": "locked_button_label",
      "label": "Locked state button label",
      "default": "Log in"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Mville+ VIP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Mville+ VIP"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Exclusive member pricing and white-glove service, just for you."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (optional)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Perk columns (desktop)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#ff5c78"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#faf8f6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "percent", "label": "Percent" },
            { "value": "tag", "label": "Tag" },
            { "value": "truck", "label": "Delivery truck" },
            { "value": "star", "label": "Star" },
            { "value": "gift", "label": "Gift" },
            { "value": "crown", "label": "Crown" },
            { "value": "shield", "label": "Shield" }
          ],
          "default": "percent"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Highlight value (e.g. 20%)",
          "info": "Shown large next to the icon. Leave blank for non-discount perks."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SS VIP Perks",
      "blocks": [
        {
          "type": "perk",
          "settings": {
            "icon": "percent",
            "value": "20%",
            "title": "Hypnos Mattresses",
            "text": "20% off the full Hypnos collection."
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "percent",
            "value": "15%",
            "title": "Marshall Curated, Aireloom Preferred & Sprout",
            "text": "15% off across these premium lines."
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "percent",
            "value": "10%",
            "title": "Marshall Inspired & Aireloom Pacific",
            "text": "10% off these collections."
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "tag",
            "value": "5%",
            "title": "Selected Products",
            "text": "5% off select items storewide."
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "truck",
            "value": "FREE",
            "title": "VIP Delivery Service",
            "text": "Complimentary white-glove delivery for Mville+ VIP members."
          }
        }
      ]
    }
  ]
}
{% endschema %}
