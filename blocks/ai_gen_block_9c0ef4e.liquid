{% doc %}
  @prompt
    a simple image block , banner image, i can adjust height to small , medium , large etc. I can turn image link on or off, off meaning the image does not link anywhere and is not clickable. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    position: relative;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--small {
    height: 300px;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--medium {
    height: 500px;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--large {
    height: 700px;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--clickable {
    cursor: pointer;
  }

  .ai-banner-image-img-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-image-wrapper-{{ ai_gen_id }}--small {
      height: 200px;
    }

    .ai-banner-image-wrapper-{{ ai_gen_id }}--medium {
      height: 350px;
    }

    .ai-banner-image-wrapper-{{ ai_gen_id }}--large {
      height: 500px;
    }
  }
{% endstyle %}

<div class="ai-banner-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.enable_link and block.settings.image_link != blank %}
    <a 
      href="{{ block.settings.image_link }}" 
      class="ai-banner-image-wrapper-{{ ai_gen_id }} ai-banner-image-wrapper-{{ ai_gen_id }}--{{ block.settings.image_height }} ai-banner-image-wrapper-{{ ai_gen_id }}--clickable"
    >
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-banner-image-img-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-banner-empty-state-{{ ai_gen_id }}">
            Add a banner image
          </div>
        </div>
      {% endif %}
    </a>
  {% else %}
    <div class="ai-banner-image-wrapper-{{ ai_gen_id }} ai-banner-image-wrapper-{{ ai_gen_id }}--{{ block.settings.image_height }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-banner-image-img-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-banner-empty-state-{{ ai_gen_id }}">
            Add a banner image
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Banner image",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Image height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "checkbox",
      "id": "enable_link",
      "label": "Enable image link",
      "default": false
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image link"
    }
  ],
  "presets": [
    {
      "name": "Banner image"
    }
  ]
}
{% endschema %}
