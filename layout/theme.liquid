{% if request.path contains '/collections/' %}
<script>
document.addEventListener('DOMContentLoaded', function() {
var pathParts = window.location.pathname.split('/').filter(function(part) {
return part.length > 0;
});



// Example valid structure: ['', 'collections', 'collection-name', 'tags...']
if (pathParts.length >= 2 && pathParts[1] === 'collections') {
  var collectionName = pathParts[2] || '';
  if (!collectionName) {
    // If collection name is missing (broken URL), redirect safely
    window.location.href = '/collections/all-mattresses';
  }
  // Otherwise, leave dynamic filters alone (NO redirect)
}
});
</script>
