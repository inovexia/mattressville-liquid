{% comment %} 
  Renders a product media gallery. Should be used with 'media-gallery.aio.min.js'
  Also see 'product-media-modal'

  Accepts: 
  - product: {Object} Product liquid object 
  - variant_images: {Array} Product images associated with a variant 
  - is_duplicate: {Boolean} Prevents rendering uneeded elements and duplicate ids for subsequent instances

  Usage:
  {% render 'product-media-gallery', is_duplicate: true %} 
{% endcomment %}

{%- liquid
  if section.settings.hide_variants and variant_images.size == product.media.size
    assign single_media_visible = true
  endif

  assign media_count = product.media.size
  if section.settings.hide_variants and media_count > 1 and variant_images.size > 0
    assign media_count = media_count | minus: variant_images.size | plus: 1
  endif

  if media_count == 1 or single_media_visible
    assign single_media_visible_mobile = true
  endif

  if media_count == 0 or single_media_visible_mobile or section.settings.mobile_thumbnails == 'show' or section.settings.mobile_thumbnails == 'columns' and media_count < 3
    assign hide_mobile_slider = true
  endif

  if section.settings.media_size == 'large'
    assign media_width = 0.65
  elsif section.settings.media_size == 'medium'
    assign media_width = 0.55
  elsif section.settings.media_size == 'small'
    assign media_width = 0.45
  endif

  assign id_append = ''
  if is_duplicate
    assign id_append = '-duplicate'
  endif
-%}

    <style>

#lg-outer-3,
#lg-outer-4 {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body .lg-toolbar .lg-icon,
body .lg-next,
body .lg-prev {
  z-index: 99999 !important;
  display: block !important;
  opacity: 1 !important;  
}

.invx-custom-gallery-slider .swiper-button-next svg, .invx-custom-gallery-slider .swiper-button-prev svg {
  display: none;
}
#lg-close-2 {
  background-color: #ff5c7b;
  color: #fff;
  margin-top: 20px;
  margin-right: 20px;
}

.invx-custom-gallery-slider .invx-gallery-video-slide video {
  display: block;
  width: 100%;
  height: auto;
}
.invx-custom-gallery-slider .invx-gallery-thumb-video {
  position: relative;
}
.invx-custom-gallery-slider .invx-gallery-thumb-play {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2rem;
  height: 2rem;
  transform: translate(-50%, -50%);
  color: #fff;
  filter: drop-shadow(0 0 2px rgba(0, 0, 0, .6));
  pointer-events: none;
}


    </style>

<div class="invx-custom-gallery-slider">
  <div style="--swiper-navigation-color: #fff; --swiper-pagination-color: #fff" class="swiper mySwiperMain">
    <div class="swiper-wrapper" id="lg-swiper">
      {%- for media in product.media -%}
        {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
          {%- if media.media_type == 'video' -%}
            <div class="swiper-slide invx-gallery-video-slide">
              {{ media | media_tag: image_size: '1946x', muted: true, loop: true, controls: true, preload: 'none' }}
            </div>
          {%- elsif media.media_type == 'external_video' -%}
            {%- liquid
              assign video_class = 'invx-gallery-video js-' | append: media.host
            -%}
            <div class="swiper-slide invx-gallery-video-slide">
              {%- if media.host == 'youtube' -%}
                {{ media | external_video_url: muted: true, loop: true, playlist: media.external_id | external_video_tag: class: video_class }}
              {%- else -%}
                {{ media | external_video_url: muted: true, loop: true | external_video_tag: class: video_class }}
              {%- endif -%}
            </div>
          {%- else -%}
            <a

              href="{{ media | img_url: 'master' }}"
              class="swiper-slide"
              rel="lightbox[gallery]">

              <img src="{{ media | img_url: 'master' }}" alt="Product Image {{ forloop.index }}" width="100%" height="auto" />
            </a>
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
  </div>
  <div thumbsSlider="" class="swiper mySwiperSmall">
    <div class="swiper-wrapper">
      {%- for media in product.media -%}
        {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
          <div class="swiper-slide{% if media.media_type == 'video' or media.media_type == 'external_video' %} invx-gallery-thumb-video{% endif %}">
            {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
              <span class="invx-gallery-thumb-play" aria-hidden="true">{% render 'icon-play' %}</span>
            {%- endif -%}
            <img src="{{ media | img_url }}" alt="Product Image {{ forloop.index }}" width="100%" height="auto" />
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll('.invx-custom-gallery-slider').forEach((gallery) => {
    const thumbsEl = gallery.querySelector('.mySwiperSmall');
    const mainEl = gallery.querySelector('.mySwiperMain');

    if (!thumbsEl || !mainEl) return;

    const thumbsSwiper = new Swiper(thumbsEl, {
      slidesPerView: 4,
      spaceBetween: 10,
      watchSlidesVisibility: true,
      watchSlidesProgress: true,
      breakpoints: {
        768: { slidesPerView: 3 },
        480: { slidesPerView: 2 }
      }
    });

    const mainSwiper = new Swiper(mainEl, {
      loop: true,
      spaceBetween: 10,
      navigation: {
        nextEl: gallery.querySelector('.swiper-button-next'),
        prevEl: gallery.querySelector('.swiper-button-prev'),
      },
      pagination: {
        el: gallery.querySelector('.swiper-pagination'),
        clickable: true,
      },
      thumbs: {
        swiper: thumbsSwiper
      },
      breakpoints: {
        768: { slidesPerView: 1 },
        480: { slidesPerView: 1 }
      }
    });

    function playSlideVideo(slide) {
      if (!slide) return;
      const video = slide.querySelector('video');
      if (video) {
        video.play().catch(() => {});
        return;
      }
      const youtube = slide.querySelector('.js-youtube');
      if (youtube && youtube.contentWindow) {
        youtube.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
      }
      const vimeo = slide.querySelector('.js-vimeo');
      if (vimeo && vimeo.contentWindow) {
        vimeo.contentWindow.postMessage('{"method":"play"}', '*');
      }
    }

    function pauseGalleryVideos(exceptSlide) {
      gallery.querySelectorAll('video').forEach((video) => {
        if (!exceptSlide || !exceptSlide.contains(video)) video.pause();
      });
      gallery.querySelectorAll('.js-youtube').forEach((iframe) => {
        if ((!exceptSlide || !exceptSlide.contains(iframe)) && iframe.contentWindow) {
          iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
        }
      });
      gallery.querySelectorAll('.js-vimeo').forEach((iframe) => {
        if ((!exceptSlide || !exceptSlide.contains(iframe)) && iframe.contentWindow) {
          iframe.contentWindow.postMessage('{"method":"pause"}', '*');
        }
      });
    }

    function syncActiveSlideVideo() {
      const activeSlide = mainSwiper.slides[mainSwiper.activeIndex];
      pauseGalleryVideos(activeSlide);
      playSlideVideo(activeSlide);
    }

    mainSwiper.on('slideChangeTransitionEnd', syncActiveSlideVideo);
    syncActiveSlideVideo();

    const mainSlider = gallery.querySelector('.mySwiperMain .swiper-wrapper');

    if (mainSlider && typeof lightGallery === 'function' && !mainSlider.dataset.lgInitialized) {
      lightGallery(mainSlider, {
        selector: 'a[rel="lightbox[gallery]"]',
        download: false,
        mobileSettings: {
          controls: true,
          showCloseIcon: true,
          download: false,
          rotate: false
        }
      });
      mainSlider.dataset.lgInitialized = "true";
    }
  });
});

</script>


